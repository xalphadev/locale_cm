# ── Locale production env — copy to .env.prod on the server (chmod 600, NEVER commit) ──
#   cp .env.prod.example .env.prod   then fill every CHANGE_ME.
# Generate secrets:   openssl rand -hex 32          (session secrets, DB passwords)
# Generate basicauth: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'YOUR_PASS'
#
# Used by:  docker compose --env-file .env.prod -f docker-compose.yml -f docker-compose.prod.yml up -d --build
#           and by db/deploy/deploy.sh (which reads the *_PASSWORD vars to provision the DB roles).

# ── Domains (DNS A records must already point at this server) ───────────────────────────
CONSUMER_DOMAIN=locale.xalpha.co.th
MERCHANT_DOMAIN=locale-merchant.xalpha.co.th
PLATFORM_DOMAIN=locale-platform.xalpha.co.th
ASSETS_DOMAIN=locale-assets.xalpha.co.th
ACME_EMAIL=CHANGE_ME@xalpha.co.th

# ── Postgres ─────────────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_ME_postgres_superuser

# DB role passwords (deploy.sh sets LOGIN+password on each; must match the URLs below) ──
MONEY_WRITER_PASSWORD=CHANGE_ME_money_writer
APP_CONTENT_PASSWORD=CHANGE_ME_app_content
APP_CONSUMER_PASSWORD=CHANGE_ME_app_consumer

# Connection strings the app containers use (host `db`, internal network). Keep the password in
# each URL identical to the matching *_PASSWORD above.
API_DATABASE_URL=postgres://money_writer:CHANGE_ME_money_writer@db:5432/locale
WEB_DATABASE_URL=postgres://app_content:CHANGE_ME_app_content@db:5432/locale
CONSUMER_DATABASE_URL=postgres://app_consumer:CHANGE_ME_app_consumer@db:5432/locale

# ── App session secrets (REQUIRED — apps refuse to boot without these in production) ────
MERCHANT_SESSION_SECRET=CHANGE_ME_32_byte_hex
CONSUMER_SESSION_SECRET=CHANGE_ME_32_byte_hex

# Secret for the headless monthly auto-billing route (/api/cron/generate-bills). Long random value.
# Passed as the `x-cron-secret` header by the in-container crontab (see the route file). Empty = auto-billing off.
CRON_SECRET=CHANGE_ME_long_random

# ── MinIO / object storage ─────────────────────────────────────────────────────────────
S3_ACCESS_KEY=CHANGE_ME_minio_user
S3_SECRET_KEY=CHANGE_ME_minio_secret
S3_BUCKET=media

# ── Platform admin (locale-platform) HTTP basic-auth ────────────────────────────────────
CADDY_BASICAUTH_USER=admin
# IMPORTANT: escape every $ as $$ (Compose interpolates $ in env values). e.g. $2a$14$abc → $$2a$$14$$abc
CADDY_BASICAUTH_HASH=CHANGE_ME_bcrypt_hash_with_dollars_doubled

# ── OAuth (optional — leave blank to hide the Google/LINE buttons) ──────────────────────
# Redirect URIs: https://locale.xalpha.co.th/auth/google/callback  and  /auth/line/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=

# ── COGS caps (fail-closed — rewards cannot mint until set; deploy.sh applies these) ────
REWARD_PER_REDEMPTION_CAP_THB=100
MERCHANT_MONTHLY_COGS_CAP_THB=100000
