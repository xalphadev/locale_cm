# The money-plane MUST connect as a role that has money_writer (sole ledger INSERT-er).
# Use SESSION-mode pooling for money txns (the plpgsql fns take SELECT ... FOR UPDATE);
# never transaction-mode pooling on the money path (silent lock/prepared-stmt trap, doc 05).
DATABASE_URL=postgres://money_app:CHANGE_ME@localhost:5432/soihop
PORT=3001
NODE_ENV=development
# Supabase (prod): direct connection on :5432 (NOT the :6543 transaction pooler).
# DATABASE_URL=postgres://money_writer:CHANGE_ME@db.<project-ref>.supabase.co:5432/postgres
