# Consumer app (Nimman Cafe-Hop). Reads places/quests/events/wallet as a SELECT-only
# role; check-in & redeem go through the money-plane API (never the DB directly).
DATABASE_URL=postgres://soihop_readonly:CHANGE_ME@localhost:5432/soihop
# Money-plane API base — server actions POST check-in / redeem here.
MONEY_API=http://127.0.0.1:3001
