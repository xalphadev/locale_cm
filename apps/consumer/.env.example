# apps/consumer — customer web. Reads broadly + writes the consumer-side non-money data directly
# (saves/likes/comments, signup, stamp/spark check-in & redeem). Connect as app_consumer
# (db/deploy/grants_app_roles.sql). Quest check-in + Coin redeem still POST to the money-plane API.
# Dev default below assumes the Docker data plane (docker compose up).
DATABASE_URL=postgres://postgres@127.0.0.1:54400/locale
# Money-plane API base — quest check-in / Coin redeem POST here.
MONEY_API=http://127.0.0.1:3001

# Consumer auth — HMAC secret for the login session cookie (REQUIRED in production).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CONSUMER_SESSION_SECRET=CHANGE_ME
# OAuth (optional — the Google/LINE buttons are hidden until BOTH id+secret are set).
# Register the redirect URI as:  <CONSUMER_BASE>/auth/google/callback  and  /auth/line/callback
# Public origin used to build the OAuth redirect URI in prod (behind a proxy / HTTPS), e.g.
# https://app.locale.com — must match the registered redirect URI. Blank in dev = the request origin.
CONSUMER_BASE=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
