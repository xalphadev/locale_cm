# Consumer app (Nimman Cafe-Hop). Reads places/quests/events/wallet as a SELECT-only
# role; check-in & redeem go through the money-plane API (never the DB directly).
DATABASE_URL=postgres://soihop_readonly:CHANGE_ME@localhost:5432/soihop
# Money-plane API base — server actions POST check-in / redeem here.
MONEY_API=http://127.0.0.1:3001
# Supabase (prod): postgres://app_readonly:CHANGE_ME@db.<project-ref>.supabase.co:5432/postgres

# Consumer auth — HMAC secret for the login session cookie (REQUIRED in production).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CONSUMER_SESSION_SECRET=CHANGE_ME
# OAuth (optional — the Google/LINE buttons are hidden until BOTH id+secret are set).
# Register the redirect URI as:  <CONSUMER_BASE>/auth/google/callback  and  /auth/line/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
# NOTE: signup creates `users` rows — the consumer DB role must be able to INSERT into users/
# profiles/user_credentials/user_identities (grant it, or route signup through the money-plane API).
