# Admin is READ-ONLY over the ledger — connect as a role that has SELECT but NOT money_writer.
# (Write/money mutations go through the NestJS money-plane, never the web client.)
DATABASE_URL=postgres://soihop_readonly:CHANGE_ME@localhost:5432/soihop
# Money-plane API base — the admin server actions (approve proposal, counter redeem,
# add place/event) POST here. Local: http://127.0.0.1:3001 · prod: your API host URL.
MONEY_API=http://127.0.0.1:3001
# Supabase (prod): postgres://app_readonly:CHANGE_ME@db.<project-ref>.supabase.co:5432/postgres
# Merchant self-service portal (/merchant) session signing key. REQUIRED in production —
# without it, server start fails (auth.ts throws) so m_session cookies can never run on a
# known/public secret. Generate: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
MERCHANT_SESSION_SECRET=CHANGE_ME_32_RANDOM_BYTES
# Consumer app base URL (for the portal's "view your public page" link). Default http://127.0.0.1:3003
CONSUMER_BASE=http://127.0.0.1:3003
