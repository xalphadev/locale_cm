# apps/web — merchant portal + back-office. Writes content directly (server actions); money/ledger
# mutations still go through the money-plane API. Connect as app_content (SELECT all + write content
# tables — see db/deploy/grants_app_roles.sql). Dev default below assumes the Docker data plane.
DATABASE_URL=postgres://postgres@127.0.0.1:54400/locale
# Money-plane API base — admin actions (approve proposal, counter redeem, add place/event) POST here.
MONEY_API=http://127.0.0.1:3001
# Merchant portal (/merchant) session signing key. REQUIRED in production — without it auth.ts throws
# on boot so m_session cookies can never run on a known/public secret.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MERCHANT_SESSION_SECRET=CHANGE_ME_32_RANDOM_BYTES
# Consumer app base URL (for the portal's "view your public page" link).
CONSUMER_BASE=http://127.0.0.1:3003

# Image storage (MinIO / S3). Dev defaults match the Docker data plane (docker compose up) — leave as-is.
# In prod these are set by docker-compose.prod.yml (endpoint=minio, ASSET_PUBLIC_BASE=https://locale-assets…).
S3_ENDPOINT=127.0.0.1
S3_PORT=9000
S3_USE_SSL=false
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=media
ASSET_PUBLIC_BASE=http://127.0.0.1:9000/media
# Environment folder inside the bucket (media/<prefix>/<kind>/...). dev locally, prod on the server.
ASSET_PREFIX=dev
